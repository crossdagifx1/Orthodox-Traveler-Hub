# Copy to .env and fill in real values.
# .env is gitignored; .env.example is committed.

# Postgres connection string. Use Neon, Supabase, Railway, Render,
# or a local Docker postgres. If left unset the api-server falls back
# to PGlite (in-memory) which loses all data on every restart.
DATABASE_URL=

# API server
PORT=8080
# Required at startup. Generate a long random string for production.
SESSION_SECRET=change-me

# Optional: override the api base URL the vite dev proxy points to.
# API_URL=http://localhost:8080
