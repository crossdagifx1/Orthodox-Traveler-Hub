{
  "name": "workspace",
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/bundle-api.mjs && pnpm --filter @workspace/guzo... --filter @workspace/api-server... --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "thread-stream": "3.1.0",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
