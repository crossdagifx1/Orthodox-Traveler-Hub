{
  "version": 2,
  "comment": "Triggering fresh deployment to resolve Vercel redeploy error",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/api-entry.mjs"
    },
    {
      "handle": "filesystem"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
